# ═══════════════════════════════════════════════════════════════
# Hotel & Restaurant SaaS — Environment Configuration
# Copy to .env and fill in all values marked <CHANGE_ME>
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=hotelrestaurant
DB_USER=postgres
DB_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
DB_POOL_MAX=10
DB_POOL_MIN=0

# ── JWT Authentication ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<CHANGE_ME_RANDOM_64_HEX>
ACCESS_TOKEN_EXPIRY=1h

# ── App ───────────────────────────────────────────────────────
APP_PORT=80
PORT=3000
NODE_ENV=production
TRUST_PROXY=1
FRONTEND_URL=https://YOUR_DOMAIN.com

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=https://YOUR_DOMAIN.com

# ── Admin Seed ────────────────────────────────────────────────
# Only used on first run (SEED_DB=true)
SEED_DB=true
ADMIN_DEFAULT_PASSWORD=<CHANGE_ME_STRONG_ADMIN_PASSWORD>

# ── Email (SMTP) ─────────────────────────────────────────────
# Leave blank to use Ethereal test email (dev only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<your-email@gmail.com>
SMTP_PASS=<your-app-specific-password>
EMAIL_FROM="Hotel SaaS <noreply@yourdomain.com>"
HOTEL_NAME=Your Hotel Name

# ── Stripe Payments (optional) ────────────────────────────────
# Leave blank to disable payment processing (admin can change plans manually)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxx

# ── Redis Cache (optional) ────────────────────────────────────
# Leave blank to use in-memory cache (fine for single-instance)
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
CACHE_TTL=300

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
