# Database (PostgreSQL)
DB_NAME=hotelrestaurant
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password
DB_HOST=localhost
DB_PORT=5432
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false  # Set to false for self-signed certs

# JWT — Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_random_secret
ACCESS_TOKEN_EXPIRY=1h

# App
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8888

# Admin seed password (only used for initial seed, change immediately after first login)
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_strong_admin_password

# Stripe (optional — leave blank to disable payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (optional — leave blank to disable email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourhotel.com

# Frontend URL (for password reset links, Stripe redirects)
FRONTEND_URL=http://localhost:5173

# Redis (optional — leave blank to use in-memory cache)
REDIS_URL=
