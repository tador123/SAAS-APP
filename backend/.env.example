# ═══════════════════════════════════════════════════════════════
# Backend Environment Configuration
# Copy this file to .env and fill in all values
# ═══════════════════════════════════════════════════════════════

# ── Database (PostgreSQL) ─────────────────────────────────────
DB_NAME=hotelrestaurant
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password
DB_HOST=localhost
DB_PORT=5432
DB_POOL_MAX=10
DB_POOL_MIN=0

# AWS RDS: Set DB_SSL=true for managed PostgreSQL
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false  # Set to false for RDS/self-signed certs

# ── JWT Authentication ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_random_secret
ACCESS_TOKEN_EXPIRY=1h

# ── App ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (comma-separated origins) ───────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8888

# ── Seed Data ─────────────────────────────────────────────────
# Only used on first run with SEED_DB=true
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_strong_admin_password

# ── Stripe (optional — leave blank to disable) ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# ── Email / SMTP (optional) ──────────────────────────────────
# Leave blank to use Ethereal test email (dev only)
# AWS SES example:
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   SMTP_PORT=587
#   SMTP_USER=<SES SMTP username>
#   SMTP_PASS=<SES SMTP password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourhotel.com

# ── Frontend URL ──────────────────────────────────────────────
# Used for password reset links, Stripe redirects
FRONTEND_URL=http://localhost:5173

# ── Redis (optional — leave blank for in-memory cache) ───────
REDIS_URL=

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug
