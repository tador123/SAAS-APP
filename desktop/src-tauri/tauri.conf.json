{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "HotelSaaS Desktop",
  "version": "1.1.0",
  "identifier": "com.hotelsaas.desktop",
  "build": {
    "frontendDist": "https://app.hotelware.in",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": "cd ../web-admin && npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "HotelSaaS Desktop",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "HotelSaaS - Running",
      "iconAsTemplate": true
    },
    "security": {
      "csp": "default-src 'self' https://app.hotelware.in; connect-src 'self' http: https:; img-src 'self' data: asset: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' https://app.hotelware.in 'unsafe-inline'; frame-src 'self' https://app.hotelware.in"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
